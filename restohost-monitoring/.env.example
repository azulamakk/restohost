# Anthropic API key — requerido para el modo LLM completo
# Obtené tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modo demo sin llamadas a la API (usar "true" para probar sin costo)
# Cuando MOCK_LLM=true el clasificador usa heurísticas locales en lugar del LLM
MOCK_LLM=false
